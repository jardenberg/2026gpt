# 2026GPT Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit the actual .env file

#===============================================================#
# Server Configuration
#===============================================================#
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

#===============================================================#
# OpenAI Direct API (Day 1 - get running immediately)
# Get your key at: https://platform.openai.com/api-keys
#===============================================================#
OPENAI_API_KEY=your-openai-api-key-here

#===============================================================#
# Azure OpenAI (Day 2+ - after Azure subscription is provisioned)
# Models: GPT-5-mini, GPT-5-nano (no registration needed)
#===============================================================#
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

#===============================================================#
# Database - MongoDB
#===============================================================#
MONGO_URI=mongodb+srv://2026gpt-admin:<password>@<cluster>.mongodb.net/2026gpt

#===============================================================#
# Search - MeiliSearch
#===============================================================#
SEARCH=true
MEILI_NO_ANALYTICS=true
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=your-meilisearch-master-key

#===============================================================#
# User Authentication
#===============================================================#
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=true
ALLOW_SOCIAL_REGISTRATION=true

# Session secrets (generate with: openssl rand -hex 32)
CREDS_KEY=generate-a-32-hex-string
CREDS_IV=generate-a-16-hex-string
JWT_SECRET=generate-a-long-random-string
JWT_REFRESH_SECRET=generate-another-long-random-string

#===============================================================#
# Social Login - Google
# Setup: https://console.cloud.google.com/apis/credentials
#===============================================================#
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=/oauth/google/callback

#===============================================================#
# Social Login - Apple
# Setup: https://developer.apple.com/account/resources/identifiers
#===============================================================#
# APPLE_CLIENT_ID=your-apple-service-id
# APPLE_TEAM_ID=your-apple-team-id
# APPLE_KEY_ID=your-apple-key-id
# APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey.p8
# APPLE_CALLBACK_URL=/oauth/apple/callback

#===============================================================#
# Social Login - GitHub
# Setup: https://github.com/settings/developers
#===============================================================#
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=/oauth/github/callback

#===============================================================#
# Social Login - Facebook
# Setup: https://developers.facebook.com/apps
#===============================================================#
# FACEBOOK_CLIENT_ID=your-facebook-app-id
# FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
# FACEBOOK_CALLBACK_URL=/oauth/facebook/callback

#===============================================================#
# Social Login - Discord
# Setup: https://discord.com/developers/applications
#===============================================================#
# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_CLIENT_SECRET=your-discord-client-secret
# DISCORD_CALLBACK_URL=/oauth/discord/callback

#===============================================================#
# File Handling
#===============================================================#
RAG_API_URL=http://rag_api:8000

#===============================================================#
# Image Generation (DALL-E via Azure)
#===============================================================#
# Configured in librechat.yaml via Azure OpenAI endpoint

#===============================================================#
# App Title / Branding
#===============================================================#
APP_TITLE=2026GPT
CUSTOM_FOOTER=Built with LibreChat | 2026GPT Demo

#===============================================================#
# Debug (set to true for development)
#===============================================================#
DEBUG_LOGGING=false
