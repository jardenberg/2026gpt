# 2026GPT Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit the actual .env file

#===============================================================#
# Server Configuration
#===============================================================#
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

#===============================================================#
# Azure OpenAI Configuration
#===============================================================#
# These are configured in librechat.yaml, but set the keys here
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
# If you have multiple Azure OpenAI resources, add more keys:
# AZURE_OPENAI_API_KEY_2=your-second-key

#===============================================================#
# Database - MongoDB
#===============================================================#
MONGO_URI=mongodb+srv://2026gpt-admin:<password>@<cluster>.mongodb.net/2026gpt

#===============================================================#
# Search - MeiliSearch
#===============================================================#
SEARCH=true
MEILI_NO_ANALYTICS=true
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=your-meilisearch-master-key

#===============================================================#
# User Authentication
#===============================================================#
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

# Session secrets (generate with: openssl rand -hex 32)
CREDS_KEY=generate-a-32-hex-string
CREDS_IV=generate-a-16-hex-string
JWT_SECRET=generate-a-long-random-string
JWT_REFRESH_SECRET=generate-another-long-random-string

#===============================================================#
# File Handling
#===============================================================#
RAG_API_URL=http://rag_api:8000

#===============================================================#
# Image Generation (DALL-E via Azure)
#===============================================================#
# Configured in librechat.yaml via Azure OpenAI endpoint

#===============================================================#
# App Title / Branding
#===============================================================#
APP_TITLE=2026GPT
CUSTOM_FOOTER=Built with LibreChat | 2026GPT Demo

#===============================================================#
# Debug (set to true for development)
#===============================================================#
DEBUG_LOGGING=false
